# DEV
FROM node:lts-alpine AS development
WORKDIR /app
COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile
COPY . .
EXPOSE 3000
CMD ["yarn", "start"]

# BUILD
FROM node:lts-alpine AS builder
WORKDIR /app
COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile
COPY . .
ARG REACT_APP_API_URL
ARG REACT_APP_TARGET_EMAIL
ARG REACT_APP_EMAIL_SERVICE
ARG REACT_APP_EMAIL_APP_ID
ARG REACT_APP_EMAIL_TEMPLATE
ARG REACT_APP_EMAIL_PUBLIC_KEY
ARG REACT_APP_SOCIALS_GITHUB
ARG REACT_APP_SOCIALS_LINKEDIN
ARG REACT_APP_SOCIALS_INSTAGRAM
ARG REACT_APP_SOCIALS_X
ARG REACT_APP_CV_LINK
ENV REACT_APP_API_URL=$REACT_APP_API_URL \
    REACT_APP_TARGET_EMAIL=$REACT_APP_TARGET_EMAIL \
    REACT_APP_EMAIL_SERVICE=$REACT_APP_EMAIL_SERVICE \
    REACT_APP_EMAIL_APP_ID=$REACT_APP_EMAIL_APP_ID \
    REACT_APP_EMAIL_TEMPLATE=$REACT_APP_EMAIL_TEMPLATE \
    REACT_APP_EMAIL_PUBLIC_KEY=$REACT_APP_EMAIL_PUBLIC_KEY \
    REACT_APP_SOCIALS_GITHUB=$REACT_APP_SOCIALS_GITHUB \
    REACT_APP_SOCIALS_LINKEDIN=$REACT_APP_SOCIALS_LINKEDIN \
    REACT_APP_SOCIALS_INSTAGRAM=$REACT_APP_SOCIALS_INSTAGRAM \
    REACT_APP_SOCIALS_X=$REACT_APP_SOCIALS_X \
    REACT_APP_CV_LINK=$REACT_APP_CV_LINK
RUN yarn build

# PROD
FROM node:lts-alpine AS production
WORKDIR /app
COPY --from=builder /app/build ./build